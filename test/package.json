{
    "name": "cockle-tests",
    "version": "1.0.0",
    "description": "Cockle tests",
    "license": "BSD-3-Clause",
    "author": "Ian Thomas",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "private": true,
    "scripts": {
        "build": "rspack build",
        "postbuild": "npm run postbuild:copy-assets && npm run postbuild:prepare-wasm",
        "postbuild:copy-assets": "copyfiles -u 1 assets/* dist/",
        "postbuild:prepare-wasm": "node node_modules/@jupyterlite/cockle/lib/tools/prepare_wasm.js --copy dist/",
        "serve": "concurrently 'npm run serve:cockle' 'npm run serve:cors-proxy'",
        "serve:cockle": "npm run serve:cross-origin",
        "serve:cross-origin": "npx static-handler --coi --port 8000 dist/",
        "serve:cors-proxy": "HOST=localhost PORT=8881 node node_modules/cors-anywhere/server.js",
        "test": "npm run test:unit && npm run test:integration",
        "test:integration": "cd integration-tests && playwright test",
        "test:integration:ui": "cd integration-tests && playwright test --ui",
        "test:unit": "jest"
    },
    "devDependencies": {
        "@jupyterlite/cockle": "file:../",
        "@playwright/test": "^1.61.1",
        "@rspack/cli": "^2.1.3",
        "@rspack/core": "^2.1.3",
        "@types/jest": "^30.0.0",
        "concurrently": "^10.0.3",
        "cors-anywhere": "^0.4.4",
        "jest": "^30.4.2",
        "static-handler": "^0.5.3",
        "ts-jest": "^29.4.11",
        "ts-loader": "^9.6.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.5.4"
    }
}
