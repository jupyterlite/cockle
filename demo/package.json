{
    "name": "cockle-demo",
    "version": "1.0.0",
    "description": "Cockle demo",
    "license": "BSD-3-Clause",
    "author": "Ian Thomas",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "private": true,
    "scripts": {
        "build": "rspack build",
        "postbuild": "npm run postbuild:copy-assets && npm run postbuild:prepare-wasm",
        "postbuild:copy-assets": "copyfiles -u 1 assets/* dist/",
        "postbuild:prepare-wasm": "node node_modules/@jupyterlite/cockle/lib/tools/prepare_wasm.js --copy dist/",
        "serve": "npm run serve:cockle",
        "serve-with-cors-proxy": "concurrently 'npm run serve:cockle' 'npm run serve:cors-proxy'",
        "serve:cockle": "npm run serve:cross-origin",
        "serve:cross-origin": "npx static-handler --coi --port 4501 dist/",
        "serve:cors-proxy": "HOST=localhost PORT=8881 node node_modules/cors-anywhere/server.js ",
        "test": "playwright test",
        "test:ui": "playwright test --ui",
        "test:report": "playwright show-report"
    },
    "devDependencies": {
        "@jupyterlite/cockle": "file:../",
        "@playwright/test": "^1.61.1",
        "@rspack/cli": "^2.1.3",
        "@rspack/core": "^2.1.3",
        "@xterm/addon-fit": "^0.11.0",
        "@xterm/xterm": "^6.0.0",
        "concurrently": "^10.0.3",
        "cors-anywhere": "^0.4.4",
        "css-loader": "^7.1.4",
        "static-handler": "^0.5.3",
        "style-loader": "^4.0.0",
        "ts-loader": "^9.6.2",
        "typescript": "^5.5.4"
    }
}
